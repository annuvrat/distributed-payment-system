# Example environment variables. Copy to .env and edit as needed.

# Postgres (used by Prisma)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/postgres

# Redis / Valkey
REDIS_HOST=valkey
REDIS_PORT=6379

# Queue
PAYMENT_QUEUE_NAME=payments

# Retry / app settings
MAX_RETRY_ATTEMPTS=3
RETRY_BASE_DELAY_MS=1000
